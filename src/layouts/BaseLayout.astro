---
import "../styles/global.css";

interface LoreLink {
  slug: string;
  title: string;
}

interface Props {
  title: string;
  loreLinks?: LoreLink[];
}

const { title, loreLinks = [] } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="app-bg text-slate-200">
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

    <!-- Header -->
    <header class="sticky top-0 z-40 border-b border-purple-900/30 bg-slate-950/85 backdrop-blur-md">
      <nav class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-3">
        <a href="/" class="group flex items-center gap-2.5">
          <span class="text-lg text-purple-400">✦</span>
          <span class="font-display text-lg font-semibold tracking-wide text-teal-100 transition group-hover:text-white">
            Crónicas de Aetheria
          </span>
        </a>
        <div class="flex items-center gap-1 text-sm">
          {[
            { href: "/", label: "Inicio" },
            { href: "/campanas/", label: "Campañas" },
            { href: "/lore/", label: "Lore" },
            { href: "/personajes/", label: "Personajes" },
          ].map(({ href, label }) => (
            <a
              href={href}
              class={`rounded-lg px-3.5 py-2 font-medium transition ${
                currentPath === href || (href !== "/" && currentPath.startsWith(href))
                  ? "bg-purple-900/50 text-purple-200"
                  : "text-slate-300 hover:bg-slate-800/60 hover:text-white"
              }`}
            >
              {label}
            </a>
          ))}
        </div>
      </nav>
    </header>

    <div class="mx-auto grid w-full max-w-7xl gap-6 px-4 py-7 lg:grid-cols-[240px_1fr]">
      <!-- Sidebar -->
      <aside class="parchment-panel h-fit space-y-6 p-5">
        <div>
          <p class="mb-3 flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-purple-300/70">
            <span>🗺️</span> Campañas
          </p>
          <ul class="space-y-1 text-sm">
            <li>
              <a
                class={`block rounded-md px-2.5 py-1.5 transition ${
                  currentPath.startsWith("/campanas/") || currentPath.startsWith("/campana/")
                    ? "bg-teal-900/40 text-teal-200"
                    : "text-slate-300 hover:bg-slate-800/50 hover:text-teal-200"
                }`}
                href="/campanas/"
              >
                Ver campañas
              </a>
            </li>
          </ul>
        </div>

        <div class="ornament-divider"><span class="text-xs">✦</span></div>

        {loreLinks.length > 0 && (
          <>
            <div>
              <p class="mb-3 flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-purple-300/70">
                <span>📜</span> Archivo de Lore
              </p>
              <ul class="space-y-1 text-sm">
                {loreLinks.map((link) => (
                  <li>
                    <a
                      class={`block rounded-md px-2.5 py-1.5 transition ${
                        currentPath === `/lore/${link.slug}/`
                          ? "bg-teal-900/40 text-teal-200"
                          : "text-slate-300 hover:bg-slate-800/50 hover:text-teal-200"
                      }`}
                      href={`/lore/${link.slug}/`}
                    >
                      {link.title}
                    </a>
                  </li>
                ))}
                <li class="pt-1">
                  <a
                    class="block rounded-md px-2.5 py-1.5 text-xs text-purple-300/60 transition hover:text-purple-200"
                    href="/lore/"
                  >
                    Ver todo el archivo →
                  </a>
                </li>
              </ul>
            </div>

            <div class="ornament-divider"><span class="text-xs">✦</span></div>
          </>
        )}

        <div>
          <p class="mb-3 flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-purple-300/70">
            <span>⚔️</span> Aventureros
          </p>
          <ul class="space-y-1 text-sm">
            <li>
              <a
                class={`block rounded-md px-2.5 py-1.5 transition ${
                  currentPath === "/personajes/"
                    ? "bg-teal-900/40 text-teal-200"
                    : "text-slate-300 hover:bg-slate-800/50 hover:text-teal-200"
                }`}
                href="/personajes/"
              >
                Ver fichas de personaje
              </a>
            </li>
          </ul>
        </div>
      </aside>

      <!-- Main content -->
      <main id="main-content" class="min-w-0 space-y-6" tabindex="-1">
        <slot />
      </main>
    </div>
  </body>
</html>
