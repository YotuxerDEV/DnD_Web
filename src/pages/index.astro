---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import HomeCampaignsList from "../components/HomeCampaignsList";
import BaseLayout from "../layouts/BaseLayout.astro";

let loreEntries: CollectionEntry<"lore">[] = [];
try {
  loreEntries = await getCollection("lore");
} catch {
  loreEntries = [];
}

const loreLinks = loreEntries.map((entry: CollectionEntry<"lore">) => ({
  slug: entry.id,
  title: entry.data.title,
}));

---

<BaseLayout title="DnD Campaña | Inicio" loreLinks={loreLinks}>
  <section class="parchment-panel space-y-5 p-6">
    <header class="border-b border-purple-900/30 pb-4">
      <h1 class="font-display text-4xl text-purple-100">Campañas disponibles</h1>
      <p class="mt-1 text-slate-400">Selecciona una campaña para continuar la aventura.</p>
    </header>

    <HomeCampaignsList client:load />
  </section>
</BaseLayout>
