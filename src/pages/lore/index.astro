---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LoreManager from "../../components/LoreManager";

let loreEntries: CollectionEntry<"lore">[] = [];
try {
  loreEntries = await getCollection("lore");
} catch {
  loreEntries = [];
}
const loreLinks = loreEntries.map((entry: CollectionEntry<"lore">) => ({
  slug: entry.id,
  title: entry.data.title,
}));
---

<BaseLayout title="Archivo de Lore | Crónicas de Aetheria" loreLinks={loreLinks}>
  <section class="parchment-panel space-y-6 p-6">
    <div class="border-b border-purple-900/30 pb-5">
      <h1 class="font-display text-4xl font-semibold tracking-wide text-purple-100">
        Archivo de Lore
      </h1>
      <p class="mt-1 text-slate-400">
        Registros de regiones, lugares y secretos del mundo de Aetheria.
      </p>
    </div>

    {loreEntries.length > 0 && (
      <div>
        <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-purple-300/60">
          Compendio base
        </p>
        <ul class="grid gap-4 sm:grid-cols-2">
          {loreEntries.map((entry: CollectionEntry<"lore">) => (
            <li>
              <a
                href={`/lore/${entry.id}/`}
                class="block rounded-lg border border-slate-700/60 bg-slate-900/40 p-4 transition hover:border-teal-700/60 hover:bg-slate-800/60"
              >
                <p class="text-xs uppercase tracking-wider text-teal-300/70">
                  {entry.data.region}
                </p>
                <h2 class="mt-1 font-display text-lg text-purple-100">{entry.data.title}</h2>
                <p class="mt-2 text-sm text-slate-300 line-clamp-2">{entry.data.summary}</p>
                {entry.data.tags && entry.data.tags.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-1">
                    {entry.data.tags.map((tag: string) => (
                      <span class="rounded-full bg-purple-900/50 px-2 py-0.5 text-xs text-purple-200">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    <LoreManager client:load />
  </section>
</BaseLayout>
