---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PersonajeHojaPage from "../../components/PersonajeHojaPage";

let loreEntries: CollectionEntry<"lore">[] = [];
try {
  loreEntries = await getCollection("lore");
} catch {
  loreEntries = [];
}
const loreLinks = loreEntries.map((entry: CollectionEntry<"lore">) => ({
  slug: entry.id,
  title: entry.data.title,
}));
---

<BaseLayout title="Hoja de Personaje | Crónicas de Aetheria" loreLinks={loreLinks}>
  <PersonajeHojaPage client:load />
</BaseLayout>
